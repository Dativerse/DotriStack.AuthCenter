{
    "env": {
        "browser": true,
        "es6": true,
        "node": true
    },
    "parser": "@babel/eslint-parser",
    "parserOptions": {
        "ecmaVersion": 8,
        "requireConfigFile": false,
        "sourceType": "module",
        "ecmaFeatures": {
            "jsx": true,
            "js": true,
            "modules": true,
            "experimentalObjectRestSpread": true
        }
    },
    "plugins": ["react"],
    "extends": [
        "eslint:recommended",
        "plugin:prettier/recommended",
        "plugin:react/recommended"
    ],
    "rules": {
        "react/prop-types": "off",
        "react/no-unescaped-entities": 0,
        "prettier/prettier": [
            "warn",
            {
                "endOfLine": "auto",
                "trailingComma": "es5",
                "semi": true,
                "singleQuote": true,
                "tabWidth": 4,
                "useTabs": false,
                "printWidth": 160,
                "jsxBracketSameLine": true
            }
        ]
    },
    "settings": {
        "react": {
            "version": "^18.2.0"
        }
    }
}
